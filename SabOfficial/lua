-- Button Creator
local function createButton(text, color, yPos)
	local btn = Instance.new("TextButton", frame)
	btn.Size = UDim2.new(1, -12, 0, 22)
	btn.Position = UDim2.new(0, 6, 0, yPos)
	btn.BackgroundColor3 = color
	btn.Text = text
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Font = Enum.Font.SourceSansBold
	btn.TextSize = 11
	btn.BorderSizePixel = 0
	return btn
end

-- Buttons (SMALL)
local lagBtn = createButton("lag em", Color3.fromRGB(70,130,180), 60)
local resetBtn = createButton("Reset", Color3.fromRGB(200,50,50), 85)
local speedBtn = createButton("Speed [E]", Color3.fromRGB(150,80,80), 110)

-- Toggle (visual only)
local enabled = false

lagBtn.MouseButton1Click:Connect(function()
	enabled = not enabled
	lagBtn.Text = enabled and "lag ON" or "lag OFF"
end)

resetBtn.MouseButton1Click:Connect(function()
	enabled = false
	lagBtn.Text = "lag em"
end)

-- Keybind
game:GetService("UserInputService").InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.E then
		speedBtn.Text = "Speed ON"
		task.wait(0.4)
		speedBtn.Text = "Speed [E]"
	end
end)
